# Gemini API Configuration (Cloud Model)
# Get a key at: https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# Ollama Local Configuration (Server-side)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="gemma4:e4b"

# Client-exposed defaults for Settings drawer
NEXT_PUBLIC_OLLAMA_HOST="http://localhost:11434"
NEXT_PUBLIC_OLLAMA_MODEL="gemma4:e4b"

# MongoDB Configuration
# Provide your local mongod connection string or MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<username>:<password>@cluster-address.mongodb.net/synapse?retryWrites=true&w=majority"
